<!DOCTYPE html>
<html>
  <head>
    <title>Dashboard</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <%= javascript_importmap_tags %>
    <!-- CKEditor CDN loader with fallback + global initializer -->
    <script>
      (function() {
        var urls = [
          'https://cdn.ckeditor.com/ckeditor5/39.0.1/classic/ckeditor.js',
          'https://cdn.jsdelivr.net/npm/@ckeditor/ckeditor5-build-classic@39.0.1/build/ckeditor.js'
        ];

        function loadScript(src, onload, onerror) {
          var s = document.createElement('script');
          s.src = src;
          s.async = true;
          s.onload = onload;
          s.onerror = onerror;
          document.head.appendChild(s);
        }

        function initGlobalCKEditors() {
          if (window.ClassicEditor) {
            document.querySelectorAll('textarea.ckeditor').forEach(function(el) {
              if (!el.classList.contains('ck-editor-loaded')) {
                window.ClassicEditor.create(el)
                  .then(function(editor) { el.classList.add('ck-editor-loaded'); })
                  .catch(function(error) { console.error('CKEditor init error:', error); });
              }
            });
          }
        }

        // Try to load sequentially with fallback
        var i = 0;
        function tryLoad() {
          if (i >= urls.length) {
            console.error('Failed to load CKEditor from all CDNs');
            return;
          }
          loadScript(urls[i], function() {
            // small delay to allow browser to process module
            setTimeout(initGlobalCKEditors, 50);
          }, function() {
            console.warn('CKEditor CDN failed, trying next:', urls[i]);
            i++; tryLoad();
          });
        }

        document.addEventListener('turbo:load', initGlobalCKEditors);
        document.addEventListener('DOMContentLoaded', function() { tryLoad(); });
      })();
    </script>
  </head>
  <body>
    <nav class="navbar navbar-dark bg-dark mb-4">
      <div class="container-fluid">
        <a class="navbar-brand" href="<%= dashboard_root_path %>">Dashboard</a>
        <div class="navbar-nav flex-row gap-3">
          <a class="nav-link" href="<%= dashboard_productos_path %>">Productos</a>
          <% if admin_user_signed_in? %>
            <%= link_to 'Salir', destroy_admin_user_session_path, method: :delete, class: 'nav-link' %>
          <% else %>
            <%= link_to 'Ingresar', new_admin_user_session_path, class: 'nav-link' %>
          <% end %>
        </div>
      </div>
    </nav>

    <div class="container">
      <% if notice %><div class="alert alert-success"><%= notice %></div><% end %>
      <% if alert %><div class="alert alert-danger"><%= alert %></div><% end %>
      <%= yield %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>