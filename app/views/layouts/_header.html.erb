
<div class="site">
        <header class="site__header d-lg-none">
            <!-- data-sticky-mode - one of [pullToShow, alwaysOnTop] -->
            <div class="mobile-header mobile-header--sticky" data-sticky-mode="pullToShow">
                <div class="mobile-header__panel">
                    <div class="container">
                        <div class="mobile-header__body">
                            <button class="mobile-header__menu-button" type="button">
                                <svg width="18px" height="14px">
                                    <use xlink:href="<%= asset_path('sprite.svg#menu-18x14') %>"></use>
                                </svg>
                            </button>
                            <a class="mobile-header__logo" href="<%= root_path %>">
                                <%= image_tag 'slides/marca.jpg', alt: 'Fascy', class: 'mobile-header__img', style: 'height:80px;width:auto;' %>
                            </a>
                        </div>
                        <div class="mobile-header__search-container">
                            <div class="container">
                                <form class="search__form" action="/home/buscar_productos" method="get">
                                    <input name="search" class="search__input" placeholder="Buscar productos" aria-label="Buscar" type="text" autocomplete="off">
                                    <button class="search__button" type="submit" aria-label="Buscar">
                                        <svg width="20px" height="20px"><use xlink:href="<%= asset_path('sprite.svg#search-20') %>"></use></svg>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- mobilemenu -->
            <div class="mobilemenu">
                <div class="mobilemenu__backdrop"></div>
                <div class="mobilemenu__body">
                    <div class="mobilemenu__header">
                        <div class="mobilemenu__title">Menu</div>
                        <button type="button" class="mobilemenu__close">
                            <svg width="20px" height="20px">
                                <use xlink:href="<%= asset_path('sprite.svg#cross-20') %>"></use>
                            </svg>
                        </button>
                    </div>
                    <div class="mobilemenu__content">
                        
                        <ul class="mobile-links mobile-links--level--0" data-collapse data-collapse-opened-class="mobile-links__item--open">
                            <li class="mobile-links__item" data-collapse-item>
                                <div class="mobile-links__item-title">
                                    <%= link_to 'Inicio', root_path, class: 'mobile-links__item-link' %>
                                </div>
                            </li>
                            <li class="mobile-links__item" data-collapse-item>
                                <div class="mobile-links__item-title">
                                    <%= link_to 'Sobre la Marca', sobre_nosotros_path, class: 'mobile-links__item-link' %>
                                </div>
                            </li>
                            <li class="mobile-links__item" data-collapse-item>
                                <div class="mobile-links__item-title">
                                    <%= link_to 'Sucursales', sucursales_path, class: 'mobile-links__item-link' %>
                                </div>
                            </li>
                            <li class="mobile-links__item" data-collapse-item>
                                <div class="mobile-links__item-title">
                                    <%= link_to 'Contacto', contacto_path, class: 'mobile-links__item-link' %>
                                </div>
                            </li>
                            <li class="mobile-links__item" data-collapse-item>
                                <div class="mobile-links__item-title">
                                    <a href="#" class="mobile-links__item-link">Categorías</a>
                                    <button class="mobile-links__item-toggle" type="button" data-collapse-trigger>
                                        <svg class="mobile-links__item-arrow" width="12px" height="7px">
                                            <use xlink:href="<%= asset_path('sprite.svg#arrow-rounded-down-12x7') %>"></use>
                                        </svg>
                                    </button>
                                </div>
                                <div class="mobile-links__item-sub-links" data-collapse-content>
                                    <ul class="mobile-links mobile-links--level--1">
                                        <% @categorias.each do |cat| %>
                                            <li class="mobile-links__item" data-collapse-item>
                                                <div class="mobile-links__item-title">
                                                    <%= link_to cat.nombre, home_categoria_path(cat), data: { turbo_frame: 'productos' }, class: 'mobile-links__item-link', onclick: "document.querySelector('.mobilemenu__close') && document.querySelector('.mobilemenu__close').click();" %>
                                                    <% if cat.subcategorias.any? %>
                                                        <button class="mobile-links__item-toggle" type="button" data-collapse-trigger>
                                                            <svg class="mobile-links__item-arrow" width="12px" height="7px">
                                                                <use xlink:href="<%= asset_path('sprite.svg#arrow-rounded-down-12x7') %>"></use>
                                                            </svg>
                                                        </button>
                                                    <% end %>
                                                </div>
                                                <% if cat.subcategorias.any? %>
                                                    <div class="mobile-links__item-sub-links" data-collapse-content>
                                                        <ul class="mobile-links mobile-links--level--2">
                                                            <% cat.subcategorias.each do |sub| %>
                                                                <li class="mobile-links__item" data-collapse-item>
                                                                    <div class="mobile-links__item-title">
                                                                        <%= link_to sub.nombre, home_categoria_path(sub), data: { turbo_frame: 'productos' }, class: 'mobile-links__item-link', onclick: "document.querySelector('.mobilemenu__close') && document.querySelector('.mobilemenu__close').click();" %>
                                                                    </div>
                                                                </li>
                                                            <% end %>
                                                        </ul>
                                                    </div>
                                                <% end %>
                                            </li>
                                        <% end %>
                                    </ul>
                                </div>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
            <!-- mobilemenu / end -->

            <script>
                document.addEventListener('DOMContentLoaded', function(){
                    function clickWhenVisible(selector, attempts){
                        attempts = attempts || 8;
                        var el = document.querySelector(selector);
                        if(el && window.getComputedStyle(el).display !== 'none'){
                            el.click();
                            return true;
                        }
                        if(attempts <= 0) return false;
                        setTimeout(function(){ clickWhenVisible(selector, attempts-1); }, 150);
                        return false;
                    }

                    function openCategories(e){
                        if(e && e.preventDefault) e.preventDefault();
                        var deptBtn = document.querySelector('.departments__button');
                        if(deptBtn && window.getComputedStyle(deptBtn).display !== 'none'){
                            deptBtn.click();
                            return;
                        }
                        var menuBtn = document.querySelector('.mobile-header__menu-button');
                        if(menuBtn){
                            menuBtn.click();
                            var attempts = 0;
                            var maxAttempts = 16;
                            var timer = setInterval(function(){
                                attempts++;
                                var items = document.querySelectorAll('.mobilemenu .mobile-links__item');
                                for(var i=0;i<items.length;i++){
                                    var link = items[i].querySelector('.mobile-links__item-link');
                                    if(!link) continue;
                                    var txt = (link.textContent || '').trim();
                                    if(/cat|categoria|categor/i.test(txt)){
                                        var trigger = items[i].querySelector('[data-collapse-trigger], .mobile-links__item-toggle');
                                        if(trigger){ trigger.click(); clearInterval(timer); return; }
                                    }
                                }
                                if(attempts>=maxAttempts) clearInterval(timer);
                            }, 200);
                            return;
                        }
                        clickWhenVisible('.departments__button');
                    }
                    var anchors = document.querySelectorAll('.mobile-header__logo, .site-header__logo');
                    anchors.forEach(function(anchor){
                        anchor.style.cursor = 'pointer';
                        anchor.addEventListener('click', openCategories);
                    });
                });
            </script>
        </header>
        <!-- desktop site__header -->
        <header class="site__header d-lg-block d-none">
            <div class="site-header">
                <!-- .topbar -->
                <!-- .topbar / end -->
                <div class="site-header__middle container">
                    <div class="site-header__logo" >
                       <img src="<%= asset_path('slides/marca.jpg') %>" alt="Marca" style="width:200px;height:80px;">
                    </div>
                    <div class="site-header__search">
                        <div class="search search--location--header ">
                            <div class="search__body">
                                <form class="search__form" action="/home/buscar_productos" method="get">
                                    <select class="search__categories" aria-label="Category" onchange="if(this.value && this.value !== 'all'){ window.location.href = '/categoria/' + this.value; }">
                                        <option value="all">Categorias</option>

                                        <% @categorias.each do |cat|%>
                                            <option value="<%= cat.slug.presence || cat.id %>"><%=cat.nombre %></option>
                                                <% cat.subcategorias.each do |sub| %>
                                                    <option value="<%= sub.slug.presence || sub.id %>">&nbsp;&nbsp;&nbsp;&nbsp; <%= sub.nombre%></option>
                                                <% end %>
                                        <% end %>
                                    </select>
                                    <input class="search__input" name="search" placeholder="Buscar productos" aria-label="Site search" type="text" autocomplete="off">
                                    <button class="search__button search__button--type--submit" type="submit">
                                        <svg width="20px" height="20px">
                                            <use xlink:href="<%= asset_path('sprite.svg#search-20') %>"></use>
                                        </svg>
                                    </button>
                                    <div class="search__border"></div>
                                </form>
                                <div class="search__suggestions suggestions suggestions--location--header"></div>
                            </div>
                        </div>
                    </div>
                    <div class="site-header__phone">
                        <div class="site-header__phone-title">Contactanos</div>
                        <div class="site-header__phone-number">(021) 209 123</div>
                    </div>
                </div>
                <div class="site-header__nav-panel">
                    <!-- data-sticky-mode - one of [pullToShow, alwaysOnTop] -->
                    <div class="nav-panel nav-panel--sticky" data-sticky-mode="pullToShow">
                        <div class="nav-panel__container container">
                            <div class="nav-panel__row">
                                <div class="nav-panel__departments">
                                    <!-- .departments -->
                                    <div class="departments" data-departments-fixed-by="">
                                        <div class="departments__body">
                                            <div class="departments__links-wrapper">
                                                <div class="departments__submenus-container"></div>
                                                <ul class="departments__links">

                                                                                                <% @categorias.each do |cat| %>
                                                                                                        <li class="departments__item">
                                                                                                                <a class="departments__item-link" href="<%= home_categoria_path(cat) %>" data-turbo-frame="productos">
                                                                                                                    <% if cat.imagen.attached? %>
                                                                                                                        <%= image_tag cat.imagen.variant(resize_to_limit: [32,32]), alt: cat.nombre, style: 'margin-right:8px;vertical-align:middle;border-radius:4px;' %>
                                                                                                                    <% else %>
                                                                                                                        <%= image_tag 'default.jpg', alt: '', style: 'width:32px;height:32px;margin-right:8px;vertical-align:middle;border-radius:4px;' %>
                                                                                                                    <% end %>
                                                                                                                    <span style="vertical-align:middle;"> <%= cat.nombre.to_s.strip %> </span>
                                                                                                                    <svg class="departments__item-arrow" width="6px" height="9px">
                                                                                                                        <use xlink:href="<%= asset_path('sprite.svg#arrow-rounded-right-6x9') %>"></use>
                                                                                                                    </svg>
                                                                                                                </a>
                                                        <div class="departments__submenu departments__submenu--type--menu">
                                                            <!-- .menu -->
                                                            <div class="menu menu--layout--classic ">
                                                                <div class="menu__submenus-container"></div>
                                                                <ul class="menu__list">
                                                                <% cat.subcategorias.each do |sub| %>
                                                                    <li class="menu__item">
                                                                        <!-- This is a synthetic element that allows to adjust the vertical offset of the submenu using CSS. -->
                                                                        <div class="menu__item-submenu-offset"></div>
                                                                        <%= link_to sub.nombre, home_categoria_path(sub), data: { turbo_frame: "productos" }, class: "menu__item-link" %>
                                                                    </li>
                                                                <% end %>    
                                                                </ul>
                                                            </div>
                                                            <!-- .menu / end -->
                                                        </div>
                                                    </li>   
                                                <% end %>
                                                </ul>
                                            </div>
                                        </div>
                                        <button class="departments__button">
                                           
                                            CATEGORIAS
                                           
                                        </button>
                                    </div>
                                    <!-- .departments / end -->
                                </div>
                                <!-- .nav-links -->
                                <div class="nav-panel__nav-links nav-links">
                                    <ul class="nav-links__list">

                                        <li class="nav-links__item ">
                                            <a class="nav-links__item-link" href="<%= sobre_nosotros_path %>">
                                                <div class="nav-links__item-body">
                                                    Sobre la Marca
                                                </div>
                                            </a>
                                        </li>
                                        
                                        <li class="nav-links__item ">
                                            <a class="nav-links__item-link" href="">
                                                <div class="nav-links__item-body">
                                                    Videos
                                                </div>
                                            </a>
                                        </li>

                                        <li class="nav-links__item ">
                                            <a class="nav-links__item-link" href="<%= sucursales_path %>">
                                                <div class="nav-links__item-body">
                                                    Sucursales
                                                </div>
                                            </a>
                                        </li>
                                        
                                        <li class="nav-links__item ">
                                            <a class="nav-links__item-link" href="<%= contacto_path %>">
                                                <div class="nav-links__item-body">
                                                   Contacto
                                                </div>
                                            </a>
                                        </li>

                                        <li class="nav-links__item ">
                                            <a class="nav-links__item-link" href="https://themeforest.net/item/stroyka-tools-store-html-template/23326943">
                                                <div class="nav-links__item-body">
                                                   Catalogo
                                                </div>
                                            </a>
                                        </li>
                                    </ul>
                                </div>
                              
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </header>