<h1>Nuevo Banner</h1>

<%= form_with(model: [:dashboard, @banner], local: true, html: { multipart: true }) do |f| %>
  <div class="mb-3">
    <%= f.label :titulo, "Título" %>
    <%= f.text_field :titulo, class: "form-control" %>
  </div>
  <div class="mb-3">
    <%= f.label :descripcion, "Descripción" %>
    <%= f.text_area :descripcion, class: "form-control" %>
  </div>
  <div class="mb-3">
    <%= f.label :tipo, "Tipo" %>
    <%= f.select :tipo, [["Principal", "principal"], ["Secundario", "secundario"]], {}, class: "form-control" %>
  </div>
  <div class="mb-3">
    <%= f.label :link, "Link" %>
    <%= f.text_field :link, class: "form-control" %>
  </div>
  <div class="mb-3">
    <%= f.label :imagen, "Imagen para escritorio" %>
    <%= f.file_field :imagen, class: "form-control", accept: "image/*" %>
    <small class="form-text text-muted">
      Proporción recomendada: horizontal panorámica (ej. 1600×500 px o 1600×650 px para banner secundario).
    </small>
  </div>
  <div class="mb-3">
    <%= f.label :imagen_mobile, "Imagen para móvil (opcional, recomendada)" %>
    <%= f.file_field :imagen_mobile, class: "form-control", accept: "image/*" %>
    <small class="form-text text-muted">
      Proporción recomendada: vertical o cuadrada (ej. 600×800 px).
      Si no cargás una imagen móvil, se recortará el centro de la imagen de escritorio.
    </small>
  </div>
  <%= f.submit "Guardar", class: "btn btn-primary" %>
  <%= link_to "Volver", dashboard_banners_path, class: "btn btn-secondary ms-2" %>
<% end %>
