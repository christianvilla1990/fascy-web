<h1>Editar Categoría</h1>

<%= form_with model: [:dashboard, @categoria], local: true, html: { multipart: true } do |f| %>
  <div class="form-group">
    <%= f.label :nombre %>
    <%= f.text_field :nombre, class: 'form-control' %>
  </div>
  <div class="form-group">
    <%= f.label :principal, '¿Principal?' %>
    <%= f.check_box :principal %>
  </div>
  <div class="form-group">
    <%= f.label :imagen %>
    <% if @categoria.imagen.attached? %>
      <div>
        <%= image_tag @categoria.imagen.variant(resize_to_limit: [100,100]) rescue image_tag @categoria.imagen %>
      </div>
    <% end %>
    <%= f.file_field :imagen, class: 'form-control' %>
  </div>
  <%= f.submit 'Guardar', class: 'btn btn-success' %>
  <%= link_to 'Volver', dashboard_categorias_path, class: 'btn btn-secondary' %>
<% end %>
