<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h4 m-0">Producto <%= @producto.id %></h1>
  <div>
    <%= link_to "Editar", edit_dashboard_producto_path(@producto), class: "btn btn-primary" %>
    <%= link_to "Volver", dashboard_productos_path, class: "btn btn-secondary ms-2" %>
  </div>
</div>

<dl class="row">
  <dt class="col-sm-3">External</dt>
  <dd class="col-sm-9"><%= @producto.external_id %></dd>
  <dt class="col-sm-3">Marca</dt>
  <dd class="col-sm-9"><%= @producto.marca&.nombre %></dd>
  <dt class="col-sm-3">Categoria</dt>
  <dd class="col-sm-9"><%= @producto.categoria&.id %></dd>
  <dt class="col-sm-3">Subcategoria</dt>
  <dd class="col-sm-9"><%= @producto.subcategoria&.id %></dd>
</dl>

<div class="mt-3 d-flex flex-wrap gap-3">
  <% if @producto.portada.present? %>
    <div>
      <strong>Portada</strong><br>
      <%= image_tag(@producto.portada.variant(resize_to_limit: [320, 320])) rescue image_tag(@producto.portada) %>
    </div>
  <% end %>
  <% @producto.otras_imagenes.each do |img| %>
    <%= image_tag(img.variant(resize_to_limit: [160, 160])) rescue image_tag(img) %>
  <% end %>
</div>
