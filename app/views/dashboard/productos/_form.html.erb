<%= form_with(model: [:dashboard, @producto], html: { class: "needs-validation" }) do |f| %>

<% api = @producto.source_api? %>
 
  <div class="mb-3">
    <%= f.label :external_id, class: "form-label" %>
    <%= f.text_field :external_id, class: "form-control", readonly: api  %>
  </div>

  <div class="row g-3">
    <div class="col-md-4">
      <%= f.label :marca_id, "Marca", class: "form-label" %>
      <%= f.collection_select :marca_id, @marcas, :id, :nombre, { include_blank: true }, class: "form-select", disabled: api %>
    </div>
    <div class="col-md-4">
      <%= f.label :categoria_id, "Categoria", class: "form-label" %>
      <%= f.collection_select :categoria_id, @categorias, :id, :nombre, { include_blank: true }, class: "form-select", disabled: api %>
    </div>
    <div class="col-md-4">
      <%= f.label :subcategoria_id, "Subcategoria", class: "form-label" %>
      <%= f.collection_select :subcategoria_id, @subcategorias, :id, :nombre, { include_blank: true }, class: "form-select", disabled: api %>
    </div>
  </div>

  <div class="mt-3">
    <%= f.label :imagenes, "Imágenes", class: "form-label" %>
    <%= f.file_field :imagenes, multiple: true, class: "form-control", accept: "image/*" %>
  </div>

  <div class="row g-3">
      <div class="col-md-4">
        <div class="form-check mt-4">
          <%= f.check_box :destacado, class: "form-check-input" %>
          <%= f.label :destacado, "Destacado", class: "form-check-label" %>
        </div>
      </div>
  <div class="col-md-4">
        <div class="form-check mt-4">
          <%= f.check_box :mas_vendido, class: "form-check-input" %>
          <%= f.label :mas_vendido, "Promo del mes", class: "form-check-label" %>
        </div>
  </div>
  <div class="col-md-4"></div>
</div>

 <% if @producto.persisted? && @producto.imagenes.attached? %>
  <div class="mt-3 d-flex flex-wrap gap-3">
    <% @producto.imagenes.each do |img| %>
      <div class="border p-2">
        <%= image_tag img.variant(resize_to_limit: [160, 160]) rescue image_tag(img) %>
        <div>
          <label>
            <%= check_box_tag "eliminar_imagenes[]", img.id %> Eliminar
          </label>
        </div>
      </div>
    <% end %>
  </div>
<% end %>

  <div class="mt-4">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancelar", @producto.persisted? ? [:dashboard, @producto] : dashboard_productos_path, class: "btn btn-secondary ms-2" %>
  </div>
<% end %>
