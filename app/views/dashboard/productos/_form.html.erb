<%= form_with(model: [:dashboard, @producto], html: { class: "needs-validation" }) do |f| %>

<% api = @producto.source_api? %>
 
  <div class="mb-3">
    <%= f.label :external_id, class: "form-label" %>
    <%= f.text_field :external_id, class: "form-control", readonly: api  %>
  </div>

  <div class="mb-3">
    <%= f.label :sku, class: "form-label" %>
    <%= f.text_field :sku, class: "form-control" %>
  </div>

  <div class="row g-3">
    <div class="col-md-4">
      <%= f.label :marca_id, "Marca", class: "form-label" %>
      <%= f.collection_select :marca_id, @marcas, :id, :nombre, { include_blank: true }, class: "form-select", disabled: api %>
    </div>
    <div class="col-md-4">
      <%= f.label :categoria_id, "Categoria", class: "form-label" %>
      <%= f.collection_select :categoria_id, @categorias, :id, :nombre, { include_blank: true }, class: "form-select", disabled: api %>
    </div>
    <div class="col-md-4">
      <%= f.label :subcategoria_id, "Subcategoria", class: "form-label" %>
      <%= f.collection_select :subcategoria_id, @subcategorias, :id, :nombre, { include_blank: true }, class: "form-select", disabled: api %>
    </div>
  </div>

  <div class="mt-3">
    <%= f.label :imagenes, "Imágenes", class: "form-label" %>
    <%= f.file_field :imagenes, multiple: true, class: "form-control", accept: "image/*" %>
  </div>
  

  <div class="row g-3">
      <div class="col-md-4">
        <div class="form-check mt-4">
          <%= f.check_box :destacado, class: "form-check-input" %>
          <%= f.label :destacado, "Destacado", class: "form-check-label" %>
        </div>
      </div>
  <div class="col-md-4">
        <div class="form-check mt-4">
          <%= f.check_box :mas_vendido, class: "form-check-input" %>
          <%= f.label :mas_vendido, "Promo del mes", class: "form-check-label" %>
        </div>
  </div>
  <div class="col-md-4"></div>
</div>

 <% if @producto.persisted? && @producto.imagenes.attached? %>
  <div class="mt-3 d-flex flex-wrap gap-3">
    <% @producto.imagenes.each do |img| %>
      <div class="border p-2">
        <%= image_tag img.variant(resize_to_limit: [160, 160]) rescue image_tag(img) %>
        <div>
          <label>
            <%= check_box_tag "eliminar_imagenes[]", img.id %> Eliminar
          </label>
        </div>
      </div>
    <% end %>
  </div>
<% end %>

  <div class="mt-4">
    <%= f.label :descripcion, "Descripción", class: "form-label" %>
    <%= f.text_area :descripcion, class: "form-control ckeditor", rows: 3 %>
  </div>

  <div class="mt-4">
    <%= f.label :especificaciones_tecnicas, "Especificaciones técnicas", class: "form-label" %>
    <%= f.text_area :especificaciones_tecnicas, class: "form-control ckeditor", rows: 5 %>
  </div>
  
  <div class="mt-3">
    <%= f.label :related_product_ids, "Productos relacionados", class: "form-label" %>
    <%= f.collection_select :related_product_ids, (@productos || []).reject { |p| p.id == @producto.id }, :id, :caracteristica, { include_hidden: false, selected: @producto.related_product_ids }, { multiple: true, class: "form-select", id: "related_products_select", data: { controller: "multiselect", multiselect_placeholder_value: "Buscar producto..." } } %>

    <script>
      (function() {
        function initTomSelect() {
          var el = document.getElementById('related_products_select')
          if (!el) return
          if (window.TomSelect) {
            try { new TomSelect(el, { plugins: ['remove_button'], persist: false, create: false, placeholder: 'Buscar producto...', maxItems: null }) } catch(e) { console.error(e) }
            return
          }
          var link = document.createElement('link')
          link.rel = 'stylesheet'
          link.href = 'https://cdn.jsdelivr.net/npm/tom-select@2.2.2/dist/css/tom-select.css'
          document.head.appendChild(link)
          var script = document.createElement('script')
          script.src = 'https://cdn.jsdelivr.net/npm/tom-select@2.2.2/dist/js/tom-select.complete.min.js'
          script.onload = function() {
            try { new TomSelect(el, { plugins: ['remove_button'], persist: false, create: false, placeholder: 'Buscar producto...', maxItems: null }) } catch(e) { console.error(e) }
          }
          document.head.appendChild(script)
        }
        if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initTomSelect)
        else initTomSelect()
      })();
    </script>
  </div>

  <div class="mt-4">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancelar", @producto.persisted? ? [:dashboard, @producto] : dashboard_productos_path, class: "btn btn-secondary ms-2" %>
  </div>
<% end %>


