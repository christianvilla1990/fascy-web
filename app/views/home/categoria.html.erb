<% if @subcategoria.present? %>
  <% content_for :title, @subcategoria.nombre %>
  <% content_for :meta_description, "Descubrí nuestra selección de productos de #{@subcategoria.nombre} en Fascy. Calidad garantizada y envíos a todo el país." %>
<% elsif @categoria.present? %>
  <% content_for :title, @categoria.nombre %>
  <% content_for :meta_description, "Explorá todos los productos de la categoría #{@categoria.nombre} en Fascy: variedad, calidad y los mejores precios." %>
<% elsif params[:id] == 'destacados' %>
  <% content_for :title, "Productos destacados" %>
  <% content_for :meta_description, "Descubrí nuestros productos destacados: los más elegidos por nuestros clientes, con calidad garantizada y los mejores precios." %>
<% elsif params[:id] == 'promo_mes' %>
  <% content_for :title, "Promociones del mes" %>
  <% content_for :meta_description, "Aprovechá las ofertas del mes en Fascy: productos seleccionados con descuentos especiales y stock limitado." %>
<% elsif params[:search].present? %>
  <% content_for :title, "Búsqueda: #{params[:search]}" %>
  <% content_for :meta_description, "Resultados de búsqueda para \"#{params[:search]}\" en Fascy. Encontrá los productos que necesitás." %>
<% end %>

<% content_for :head do %>
  <%
    crumbs = [["Inicio", root_url]]
    if @subcategoria.present?
      if @subcategoria.respond_to?(:categoria) && @subcategoria.categoria.present?
        crumbs << [@subcategoria.categoria.nombre, home_categoria_url(@subcategoria.categoria)]
      end
      crumbs << [@subcategoria.nombre, home_categoria_url(@subcategoria)]
    elsif @categoria.present?
      crumbs << [@categoria.nombre, home_categoria_url(@categoria)]
    elsif params[:id] == 'destacados'
      crumbs << ["Productos destacados", home_categoria_url('destacados')]
    elsif params[:id] == 'promo_mes'
      crumbs << ["Promociones del mes", home_categoria_url('promo_mes')]
    end
  %>
  <%= json_ld_breadcrumbs(crumbs) if crumbs.size > 1 %>
<% end %>

<%= turbo_frame_tag "productos" do %>
  <div class="site__body">
    <div class="page-header">
      <div class="page-header__container container">
        <div class="page-header__breadcrumb">
          <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
              <li class="breadcrumb-item">
                <a href="/">INICIO</a>
                <svg class="breadcrumb-arrow" width="6" height="9">
                  <use xlink:href="images/sprite.svg#arrow-rounded-right-6x9"></use>
                </svg>
              </li>
              <li class="breadcrumb-item active" aria-current="page">
                <% if defined?(@subcategoria) && @subcategoria.present? %>
                  <%= @subcategoria.nombre %>
                <% elsif defined?(@categoria) && @categoria.present? %>
                  <%= @categoria.nombre %>
                <% end %>
              </li>
            </ol>
          </nav>
        </div>
        <div class="page-header__title">
          <h1>
            <% if params[:id] == 'destacados' %>
              Productos destacados
            <% elsif params[:id] == 'promo_mes' %>
              Promo del Mes
            <% elsif defined?(@subcategoria) && @subcategoria.present? %>
              <%= @subcategoria.nombre %>
            <% elsif defined?(@categoria) && @categoria.present? %>
              <%= @categoria.nombre %>
            <% end %>
          </h1>
        </div>
      </div>
    </div>

    <div class="container">
      <div class="row">
        <div class="col-12">
          <div class="block">
            <div class="products-view">
              <div class="products-view__options">
                <!-- ...existing code... -->
              </div>

              <% if @productos.any? %>
                <div class="products-view__list products-list" data-layout="grid-4-full" data-with-features="false" data-mobile-grid-columns="2">
                  <div class="products-list__body">
                    <% @productos.each do |p| %>
                      <div class="products-list__item">
                        <div class="product-card product-card--hidden-actions">
                          <button class="product-card__quickview" type="button">
                            <svg width="16" height="16"><use xlink:href="images/sprite.svg#quickview-16"></use></svg>
                            <span class="fake-svg-icon"></span>
                          </button>

                          <div class="product-card__badges-list">
                            <div class="product-card__badge product-card__badge--new">New</div>
                          </div>

                          <div class="product-card__image product-image">
                              <%= link_to home_productos_detalle_path(p), data: { turbo_frame: "productos-detalle" }, class: "product-image__body" do %>
                                  <% portada = p.imagen_portada %>
                                  <% if portada.present? %>
                                    <%= image_tag portada.variant(resize_to_limit: [600, 600]).processed,
                                                  alt: p.caracteristica,
                                                  class: "product-image__img" %>
                                  <% else %>
                                    <img class="product-image__img" src="<%= asset_path('products/product-1.jpg') %>" alt="<%= p.caracteristica %>">
                                  <% end %>
                               <% end %>
                          </div>

                          <div class="product-card__info">
                            <div class="product-card__name">
                              <%= link_to home_productos_detalle_path(p), data: { turbo_frame: "productos-detalle" } do %>
                                  <%= p.caracteristica %>
                              <% end %>
                            </div>
                            <!-- ...rating u otros datos... -->
                          </div>
                        </div>
                      </div>
                    <% end %>
                  </div>
                </div>
              <% else %>
                <p>Sin productos en esta subcategoría.</p>
              <% end %>

            </div>

            <% if @pagy.pages > 1 %>
                <div class="products-view__pagination">
                  <ul class="pagination justify-content-center">
                    <%== pagy_bootstrap_nav(@pagy)
                          .gsub('href="', 'data-turbo-frame="productos" href="') %>
                  </ul>
                </div>
            <% end %>

            <%= turbo_frame_tag "productos-detalle" do %>
                   
            <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>