<% content_for :title, "Sobre Nosotros" %>
<% content_for :meta_description, "Conocé Fascy: nuestra historia, misión, valores y por qué elegirnos. Más de 15 años ofreciendo productos de calidad con atención cercana en todo Paraguay." %>

<div class="site__body sobre-nosotros">
  <style>
    .sobre-nosotros { color: #2b2b2b; }

    /* Hero */
    .sobre-hero {
      background: linear-gradient(135deg, #fff8e1 0%, #fff4d1 60%, #ffe7a3 100%);
      padding: 80px 0 70px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .sobre-hero::before {
      content: '';
      position: absolute;
      top: -80px; right: -80px;
      width: 300px; height: 300px;
      background: rgba(255, 184, 40, 0.15);
      border-radius: 50%;
    }
    .sobre-hero::after {
      content: '';
      position: absolute;
      bottom: -100px; left: -60px;
      width: 260px; height: 260px;
      background: rgba(255, 184, 40, 0.1);
      border-radius: 50%;
    }
    .sobre-hero__container { position: relative; z-index: 1; max-width: 820px; margin: 0 auto; padding: 0 1rem; }
    .sobre-hero__eyebrow {
      display: inline-block;
      background: #ffb828;
      color: #2b2b2b;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 6px 14px;
      border-radius: 999px;
      margin-bottom: 20px;
    }
    .sobre-hero__title {
      font-size: 3rem;
      font-weight: 700;
      line-height: 1.1;
      margin-bottom: 18px;
      letter-spacing: -0.01em;
    }
    .sobre-hero__subtitle {
      font-size: 1.15rem;
      line-height: 1.6;
      color: #555;
      max-width: 640px;
      margin: 0 auto;
    }

    /* Generic section */
    .sobre-section { padding: 70px 0; }
    .sobre-section--alt { background: #fafafa; }
    .sobre-section__inner { max-width: 1140px; margin: 0 auto; padding: 0 1rem; }
    .sobre-section__header { text-align: center; margin-bottom: 48px; }
    .sobre-section__eyebrow {
      color: #ffb828;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      margin-bottom: 10px;
    }
    .sobre-section__title {
      font-size: 2.1rem;
      font-weight: 700;
      margin-bottom: 14px;
      letter-spacing: -0.01em;
    }
    .sobre-section__lead {
      font-size: 1.02rem;
      color: #666;
      line-height: 1.7;
      max-width: 680px;
      margin: 0 auto;
    }

    /* Nuestra historia - split layout */
    .sobre-historia { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center; }
    .sobre-historia__text h2 { font-size: 2rem; font-weight: 700; margin-bottom: 20px; letter-spacing: -0.01em; }
    .sobre-historia__text p { font-size: 1.02rem; line-height: 1.75; color: #555; margin-bottom: 16px; }
    .sobre-historia__image {
      border-radius: 18px;
      overflow: hidden;
      box-shadow: 0 20px 50px rgba(0,0,0,0.12);
      aspect-ratio: 4/3;
      background: linear-gradient(135deg, #ffb828 0%, #ff9a1c 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      font-size: 1rem;
      font-weight: 600;
      letter-spacing: 0.05em;
    }

    /* Tarjetas misión/visión/valores */
    .sobre-cards {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
    .sobre-card {
      background: #fff;
      border-radius: 16px;
      padding: 36px 28px;
      box-shadow: 0 4px 16px rgba(0,0,0,0.06);
      transition: transform .3s ease, box-shadow .3s ease;
      border-top: 4px solid #ffb828;
    }
    .sobre-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 16px 36px rgba(0,0,0,0.1);
    }
    .sobre-card__icon {
      width: 56px; height: 56px;
      border-radius: 14px;
      background: rgba(255, 184, 40, 0.18);
      display: flex; align-items: center; justify-content: center;
      font-size: 26px;
      margin-bottom: 18px;
    }
    .sobre-card__title { font-size: 1.25rem; font-weight: 700; margin-bottom: 10px; }
    .sobre-card__text { color: #666; line-height: 1.6; font-size: 0.95rem; }

    /* Features grid */
    .sobre-features { display: grid; grid-template-columns: repeat(4, 1fr); gap: 28px; }
    .sobre-feature { text-align: center; padding: 20px 14px; }
    .sobre-feature__icon {
      width: 72px; height: 72px;
      border-radius: 50%;
      background: #fff;
      box-shadow: 0 6px 18px rgba(255, 184, 40, 0.3);
      display: inline-flex; align-items: center; justify-content: center;
      font-size: 30px;
      margin-bottom: 18px;
    }
    .sobre-feature__title { font-weight: 700; margin-bottom: 8px; font-size: 1.05rem; }
    .sobre-feature__text { font-size: 0.9rem; color: #666; line-height: 1.5; }

    /* Stats */
    .sobre-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; text-align: center; }
    .sobre-stat__number {
      font-size: 2.8rem; font-weight: 800; color: #ffb828;
      line-height: 1; margin-bottom: 8px;
      letter-spacing: -0.02em;
    }
    .sobre-stat__label {
      font-size: 0.9rem; color: #555;
      text-transform: uppercase; letter-spacing: 0.08em;
      font-weight: 600;
    }

    /* CTA */
    .sobre-cta {
      background: linear-gradient(135deg, #2b2b2b 0%, #1a1a1a 100%);
      color: #fff;
      padding: 70px 0;
      text-align: center;
    }
    .sobre-cta__title { font-size: 2rem; font-weight: 700; margin-bottom: 12px; letter-spacing: -0.01em; }
    .sobre-cta__text { color: #bbb; max-width: 540px; margin: 0 auto 28px; line-height: 1.6; }
    .sobre-cta__btn {
      display: inline-block;
      background: #ffb828;
      color: #2b2b2b;
      font-weight: 700;
      padding: 14px 36px;
      border-radius: 999px;
      text-decoration: none;
      transition: transform .2s ease, box-shadow .2s ease;
      letter-spacing: 0.02em;
    }
    .sobre-cta__btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 24px rgba(255,184,40,0.45);
      color: #2b2b2b;
    }

    /* Responsive */
    @media (max-width: 991px) {
      .sobre-hero__title { font-size: 2.4rem; }
      .sobre-historia { grid-template-columns: 1fr; gap: 40px; }
      .sobre-cards { grid-template-columns: 1fr 1fr; }
      .sobre-features { grid-template-columns: 1fr 1fr; gap: 36px; }
      .sobre-stats { grid-template-columns: 1fr 1fr; gap: 32px; }
    }
    @media (max-width: 575px) {
      .sobre-hero { padding: 60px 0 50px; }
      .sobre-hero__title { font-size: 1.9rem; }
      .sobre-hero__subtitle { font-size: 1rem; }
      .sobre-section { padding: 50px 0; }
      .sobre-section__title { font-size: 1.6rem; }
      .sobre-cards { grid-template-columns: 1fr; }
      .sobre-historia__text h2 { font-size: 1.55rem; }
      .sobre-stat__number { font-size: 2.2rem; }
      .sobre-cta__title { font-size: 1.55rem; }
    }
  </style>

  <!-- Hero -->
  <section class="sobre-hero">
    <div class="sobre-hero__container">
      <span class="sobre-hero__eyebrow">Sobre la marca</span>
      <h1 class="sobre-hero__title">Calidad y confianza en cada producto</h1>
      <p class="sobre-hero__subtitle">
        Somos una empresa dedicada a ofrecer productos de alta calidad que acompañan el día a día de nuestros clientes. Conocé nuestra historia y lo que nos hace únicos.
      </p>
    </div>
  </section>

  <!-- Nuestra historia -->
  <section class="sobre-section">
    <div class="sobre-section__inner">
      <div class="sobre-historia">
        <div class="sobre-historia__text">
          <div class="sobre-section__eyebrow">Nuestra historia</div>
          <h2>Más que productos, una tradición</h2>
          <p>
            Fascy nació con la visión de brindar a cada hogar y comercio acceso a productos confiables, seleccionados con el mayor cuidado. Lo que comenzó como un pequeño emprendimiento familiar, hoy es una marca reconocida que llega a miles de clientes.
          </p>
          <p>
            Cada artículo que ofrecemos pasa por un riguroso proceso de selección, porque entendemos que la confianza se gana producto a producto, cliente a cliente.
          </p>
        </div>
        <div class="sobre-historia__image">
          Foto de la empresa
        </div>
      </div>
    </div>
  </section>

  <!-- Misión, Visión, Valores -->
  <section class="sobre-section sobre-section--alt">
    <div class="sobre-section__inner">
      <div class="sobre-section__header">
        <div class="sobre-section__eyebrow">Qué nos mueve</div>
        <h2 class="sobre-section__title">Misión, visión y valores</h2>
        <p class="sobre-section__lead">Los principios que guían cada decisión que tomamos y cada producto que ofrecemos.</p>
      </div>

      <div class="sobre-cards">
        <div class="sobre-card">
          <div class="sobre-card__icon">🎯</div>
          <h3 class="sobre-card__title">Misión</h3>
          <p class="sobre-card__text">
            Ofrecer productos de calidad superior a precios accesibles, brindando a nuestros clientes una experiencia de compra simple, confiable y memorable.
          </p>
        </div>
        <div class="sobre-card">
          <div class="sobre-card__icon">🚀</div>
          <h3 class="sobre-card__title">Visión</h3>
          <p class="sobre-card__text">
            Ser la marca líder y referente del rubro, reconocida por la excelencia en el servicio, la innovación constante y el compromiso con nuestra comunidad.
          </p>
        </div>
        <div class="sobre-card">
          <div class="sobre-card__icon">💎</div>
          <h3 class="sobre-card__title">Valores</h3>
          <p class="sobre-card__text">
            Honestidad, compromiso, calidad e innovación. Construimos relaciones duraderas basadas en la confianza y el respeto hacia cada persona.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="sobre-section">
    <div class="sobre-section__inner">
      <div class="sobre-stats">
        <div>
          <div class="sobre-stat__number">+15</div>
          <div class="sobre-stat__label">Años de experiencia</div>
        </div>
        <div>
          <div class="sobre-stat__number">+500</div>
          <div class="sobre-stat__label">Productos disponibles</div>
        </div>
        <div>
          <div class="sobre-stat__number">+10K</div>
          <div class="sobre-stat__label">Clientes satisfechos</div>
        </div>
        <div>
          <div class="sobre-stat__number">24/7</div>
          <div class="sobre-stat__label">Atención online</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Lo que nos diferencia -->
  <section class="sobre-section sobre-section--alt">
    <div class="sobre-section__inner">
      <div class="sobre-section__header">
        <div class="sobre-section__eyebrow">Por qué elegirnos</div>
        <h2 class="sobre-section__title">Lo que nos diferencia</h2>
      </div>
      <div class="sobre-features">
        <div class="sobre-feature">
          <div class="sobre-feature__icon">✨</div>
          <h3 class="sobre-feature__title">Calidad garantizada</h3>
          <p class="sobre-feature__text">Seleccionamos cuidadosamente cada producto que ofrecemos.</p>
        </div>
        <div class="sobre-feature">
          <div class="sobre-feature__icon">🚚</div>
          <h3 class="sobre-feature__title">Envíos rápidos</h3>
          <p class="sobre-feature__text">Llegamos a todo el país con logística confiable y eficiente.</p>
        </div>
        <div class="sobre-feature">
          <div class="sobre-feature__icon">💬</div>
          <h3 class="sobre-feature__title">Atención cercana</h3>
          <p class="sobre-feature__text">Un equipo humano listo para ayudarte antes, durante y después de tu compra.</p>
        </div>
        <div class="sobre-feature">
          <div class="sobre-feature__icon">🔒</div>
          <h3 class="sobre-feature__title">Compra segura</h3>
          <p class="sobre-feature__text">Tus datos y pagos protegidos en cada transacción.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="sobre-cta">
    <div class="sobre-section__inner">
      <h2 class="sobre-cta__title">¿Listo para descubrir nuestros productos?</h2>
      <p class="sobre-cta__text">
        Explorá nuestro catálogo completo y encontrá todo lo que necesitás, con la calidad y confianza que nos caracteriza.
      </p>
      <%= link_to "Ver catálogo", root_path, class: "sobre-cta__btn" %>
    </div>
  </section>

  <%= render 'footer' %>
</div>
