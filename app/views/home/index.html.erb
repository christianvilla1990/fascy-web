<%= content_for :head do %>
  <%= json_ld_organization %>
<% end %>

<div class="site__body">
    <h1 class="visually-hidden" style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0;">
      Fascy — Herramientas, productos y soluciones de calidad en Paraguay
    </h1>

             <%= render 'banner_principal' %>
        
        <!-- .block-slideshow / end -->
             <%= render 'productos_destacados' %>
            <!-- Aquí continúa el resto del contenido original de la página -->

            <%= render 'banner_secundario' %>  

            <%= render 'productos_promo' %>

            <% categorias_principales = Categoria.where(principal: true).order(:prioridad) %>
            <%= render partial: 'categorias_principales', locals: { categorias: categorias_principales } %>

            <script>
                document.addEventListener('DOMContentLoaded', function(){
                    function clickWhenVisible(selector, attempts){
                        attempts = attempts || 8;
                        var el = document.querySelector(selector);
                        if(el && window.getComputedStyle(el).display !== 'none'){
                            el.click();
                            return true;
                        }
                        if(attempts <= 0) return false;
                        setTimeout(function(){ clickWhenVisible(selector, attempts-1); }, 150);
                        return false;
                    }

                    function openMobileCategories(e){
                        if(e && e.preventDefault) e.preventDefault();

                        // If desktop departments button exists and visible, click it
                        var deptBtn = document.querySelector('.departments__button');
                        if(deptBtn && window.getComputedStyle(deptBtn).display !== 'none'){
                            deptBtn.click();
                            return;
                        }

                        // Otherwise open mobile menu and then open the "Categories" collapse
                        var menuBtn = document.querySelector('.mobile-header__menu-button');
                        if(menuBtn){
                            menuBtn.click();

                            var tryOpen = function(attemptsLeft){
                                // find mobilemenu Categories/Categorías item by link text (case-insensitive, fuzzy 'cat')
                                var items = document.querySelectorAll('.mobilemenu .mobile-links__item');
                                var re = /cat/i;
                                for(var i=0;i<items.length;i++){
                                    var link = items[i].querySelector('.mobile-links__item-link');
                                    if(!link) continue;
                                    var txt = link.textContent.trim();
                                    if(re.test(txt)){
                                        var trigger = items[i].querySelector('[data-collapse-trigger]');
                                        if(trigger){ trigger.click(); return true; }
                                    }
                                }

                                if(attemptsLeft > 0){
                                    setTimeout(function(){ tryOpen(attemptsLeft-1); }, 150);
                                }
                                return false;
                            };

                            setTimeout(function(){ tryOpen(12); }, 200);
                        }
                    }

                    // attach to mobile logo and any categories button we added
                    var anchors = document.querySelectorAll('.mobile-header__logo, .site-header__logo');
                    anchors.forEach(function(anchor){
                        anchor.style.cursor = 'pointer';
                        anchor.addEventListener('click', function(e){
                            if(window.matchMedia('(max-width: 991px)').matches){
                                openMobileCategories(e);
                            }
                        });
                    });

                    // categories button removed; no-op
                });
            </script>

            <%= render 'footer'%>
 </div>


            