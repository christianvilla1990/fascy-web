<!-- site -->
<div class="site">
    <div class="site__body">
        <!-- .block-slideshow -->
        <div class="block-slideshow block-slideshow--layout--with-departments block">
            <div class="container">
                <div class="row">
                    <div class="col-lg-3 d-none d-lg-block"></div>
                    <div class="col-12 col-lg-12">
                        <div class="block-slideshow__body">
                            <div class="owl-carousel">
                                <% @banners_principales.each do |banner| %>
                                    <a class="block-slideshow__slide" href="<%= banner.link %>">
                                        <% if banner.imagen.attached? %>
                                            <div class="block-slideshow__slide-image block-slideshow__slide-image--desktop" style="background-image: url('<%= url_for(banner.imagen) %>')"></div>
                                            <div class="block-slideshow__slide-image block-slideshow__slide-image--mobile" style="background-image: url('<%= url_for(banner.imagen) %>')"></div>
                                        <% end %>
                                        <div class="block-slideshow__slide-content">
                                            <div class="block-slideshow__slide-title"><%= banner.titulo %></div>
                                            <div class="block-slideshow__slide-text"><%= banner.descripcion %></div>
                                            <div class="block-slideshow__slide-button">
                                                <span class="btn btn-primary btn-lg">Ver más</span>
                                            </div>
                                        </div>
                                    </a>
                                <% end %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
         <div class="block block-features block-features--layout--classic">
                <div class="container">
                    <div class="block-features__list">
                        <div class="block-features__item">
                            <div class="block-features__icon">
                                <svg width="48px" height="48px">
                                    <use xlink:href="images/sprite.svg#fi-free-delivery-48"></use>
                                </svg>
                            </div>
                            <div class="block-features__content">
                                <div class="block-features__title">Free Shipping</div>
                                <div class="block-features__subtitle">For orders from $50</div>
                            </div>
                        </div>
                        <div class="block-features__divider"></div>
                        <div class="block-features__item">
                            <div class="block-features__icon">
                                <svg width="48px" height="48px">
                                    <use xlink:href="images/sprite.svg#fi-24-hours-48"></use>
                                </svg>
                            </div>
                            <div class="block-features__content">
                                <div class="block-features__title">Support 24/7</div>
                                <div class="block-features__subtitle">Call us anytime</div>
                            </div>
                        </div>
                        <div class="block-features__divider"></div>
                        <div class="block-features__item">
                            <div class="block-features__icon">
                                <svg width="48px" height="48px">
                                    <use xlink:href="images/sprite.svg#fi-payment-security-48"></use>
                                </svg>
                            </div>
                            <div class="block-features__content">
                                <div class="block-features__title">100% Safety</div>
                                <div class="block-features__subtitle">Only secure payments</div>
                            </div>
                        </div>
                        <div class="block-features__divider"></div>
                        <div class="block-features__item">
                            <div class="block-features__icon">
                                <svg width="48px" height="48px">
                                    <use xlink:href="images/sprite.svg#fi-tag-48"></use>
                                </svg>
                            </div>
                            <div class="block-features__content">
                                <div class="block-features__title">Hot Offers</div>
                                <div class="block-features__subtitle">Discounts up to 90%</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        
        <!-- .block-slideshow / end -->
                        <%= render 'productos_destacados' %>
            <!-- Aquí continúa el resto del contenido original de la página -->

            <%= render 'banner_secundario' %>  

            <%= render 'productos_promo' %>

            <% categorias_principales = Categoria.where(principal: true).order(:prioridad) %>
            <%= render partial: 'categorias_principales', locals: { categorias: categorias_principales } %>

            <script>
                document.addEventListener('DOMContentLoaded', function(){
                    function clickWhenVisible(selector, attempts){
                        attempts = attempts || 8;
                        var el = document.querySelector(selector);
                        if(el && window.getComputedStyle(el).display !== 'none'){
                            el.click();
                            return true;
                        }
                        if(attempts <= 0) return false;
                        setTimeout(function(){ clickWhenVisible(selector, attempts-1); }, 150);
                        return false;
                    }

                    function openMobileCategories(e){
                        if(e && e.preventDefault) e.preventDefault();

                        // If desktop departments button exists and visible, click it
                        var deptBtn = document.querySelector('.departments__button');
                        if(deptBtn && window.getComputedStyle(deptBtn).display !== 'none'){
                            deptBtn.click();
                            return;
                        }

                        // Otherwise open mobile menu and then open the "Categories" collapse
                        var menuBtn = document.querySelector('.mobile-header__menu-button');
                        if(menuBtn){
                            menuBtn.click();

                            var tryOpen = function(attemptsLeft){
                                // find mobilemenu Categories/Categorías item by link text (case-insensitive, fuzzy 'cat')
                                var items = document.querySelectorAll('.mobilemenu .mobile-links__item');
                                var re = /cat/i;
                                for(var i=0;i<items.length;i++){
                                    var link = items[i].querySelector('.mobile-links__item-link');
                                    if(!link) continue;
                                    var txt = link.textContent.trim();
                                    if(re.test(txt)){
                                        var trigger = items[i].querySelector('[data-collapse-trigger]');
                                        if(trigger){ trigger.click(); return true; }
                                    }
                                }

                                if(attemptsLeft > 0){
                                    setTimeout(function(){ tryOpen(attemptsLeft-1); }, 150);
                                }
                                return false;
                            };

                            setTimeout(function(){ tryOpen(12); }, 200);
                        }
                    }

                    // attach to mobile logo and any categories button we added
                    var anchors = document.querySelectorAll('.mobile-header__logo, .site-header__logo');
                    anchors.forEach(function(anchor){
                        anchor.style.cursor = 'pointer';
                        anchor.addEventListener('click', function(e){
                            if(window.matchMedia('(max-width: 991px)').matches){
                                openMobileCategories(e);
                            }
                        });
                    });

                    // categories button removed; no-op
                });
            </script>

            <%= render 'footer'%>
    </div>
</div>