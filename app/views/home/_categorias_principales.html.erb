            <div class="block block--highlighted block-categories block-categories--layout--classic">
              <div class="container">
                <div class="block-header">
                  <h3 class="block-header__title">Categorías principales</h3>
                  <div class="block-header__divider"></div>
                </div>
                <style>
                  /* category image hover: lift effect */
                  .block-categories__list.owl-carousel{gap:0.5rem}
                  .block-categories__item{margin:0 6px}
                  .block-categories .category-card__image{background:#fff;padding:8px;border-radius:10px;overflow:hidden}
                  .block-categories .category-card__image a{display:flex;align-items:center;justify-content:center;height:auto}
                  .block-categories .category-card__image img{transition: transform .6s cubic-bezier(.2,.8,.2,1), box-shadow .6s ease;width:100%;height:auto;max-height:420px;object-fit:contain}
                  .block-categories .category-card__image:hover img,
                  .block-categories .category-card__image:focus-within img{transform: translateY(-6px) scale(1.03);box-shadow:0 10px 20px rgba(0,0,0,0.12)}

                  /* category name: limit long names to two lines with ellipsis on small screens */
                  .block-categories .category-card__name{font-size:1rem;max-width:240px;text-align:center;margin-top:0.6rem}
                  .block-categories .category-card__name a{display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;text-overflow:ellipsis;white-space:normal}

                  /* center carousel items when there are few categories */
                  .block-categories__list.owl-carousel{display:flex;justify-content:center;align-items:stretch}
                  .block-categories__item{margin:0 auto}

                  @media (max-width: 767px) {
                    /* let image fill container width and keep aspect ratio to avoid thin/tall appearance */
                    .block-categories .category-card__image a{height:auto}
                    .block-categories .category-card__image{padding:8px}
                    .block-categories .category-card__image img{width:100%;height:auto;object-fit:contain;max-height:420px}
                    .block-categories .category-card__name{max-width:180px;font-size:0.95rem}
                  }
                </style>
                <div class="block-categories__list owl-carousel" id="categorias-carousel">
                  <% categorias.each do |categoria| %>
                    <div class="block-categories__item category-card category-card--layout--classic">
                      <div class="category-card__body" style="display: flex; flex-direction: column; align-items: center;">
                        <div class="category-card__image">
                          <a href="<%= home_categoria_path(categoria.id) %>">
                            <% if categoria.imagen.attached? %>
                              <%= image_tag categoria.imagen.variant(resize_to_limit: [720,720]), alt: categoria.nombre, class: 'img-fluid' %>
                            <% else %>
                              <img src="/images/categories/default.jpg" alt="<%= categoria.nombre %>" class="img-fluid">
                            <% end %>
                          </a>
                        </div>
                        <div class="category-card__name">
                          <a href="<%= home_categoria_path(categoria.id) %>"> <%= categoria.nombre %> </a>
                        </div>
                        <div class="category-card__content">
                          <div class="category-card__all">
                            <a href="<%= home_categoria_path(categoria.id) %>">Ver todo</a>
                          </div>
                          <div class="category-card__products">
                            <%= categoria.productos.count %> Productos
                          </div>
                        </div>
                      </div>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>
            <script>
              document.addEventListener('DOMContentLoaded', function() {
                if (window.$ && $.fn.owlCarousel) {
                  $('#categorias-carousel').owlCarousel({
                    items: 3,
                    loop: true,
                    margin: 8,
                    autoplay: true,
                    autoplayTimeout: 3500,
                    autoplayHoverPause: true,
                    responsive: {
                      0: { items: 2 },
                      480: { items: 2 },
                      600: { items: 3 },
                      1000: { items: 3 }
                    }
                  });
                }
              });
            </script>