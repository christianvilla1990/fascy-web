            <div class="block block--highlighted block-categories block-categories--layout--classic">
              <div class="container">
                <div class="block-header">
                  <h3 class="block-header__title">Categorías principales</h3>
                  <div class="block-header__divider"></div>
                </div>
                <style>
                  /* Compact, responsive category cards */
                  .block-categories__list.owl-carousel { display: block; }
                  .block-categories__item { margin: 0; }

                  /* Card container: full width, block level */
                  .block-categories .category-card { display: block; width: 100%; }

                  /* Body: vertical stack, children stretched to full width */
                  .block-categories .category-card .category-card__body {
                    display: flex;
                    flex-direction: column;
                    align-items: stretch;
                    padding: 8px;
                    background: #fff;
                    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
                    border-radius: 10px;
                    text-align: center;
                    width: 100%;
                  }

                  /* Image container: full width of card, no extra padding */
                  .block-categories .category-card .category-card__image {
                    width: 100% !important;
                    margin: 0 0 8px 0 !important;
                    padding: 0;
                    background: transparent;
                    border-radius: 8px;
                    overflow: hidden;
                    flex-shrink: 0;
                  }
                  .block-categories .category-card .category-card__image a {
                    display: block;
                    width: 100%;
                    height: auto;
                  }
                  .block-categories .category-card .category-card__image img {
                    width: 100%;
                    height: auto;
                    max-height: none;
                    display: block;
                    border-radius: 8px;
                    transition: transform .5s cubic-bezier(.2,.8,.2,1), box-shadow .5s ease;
                  }
                  .block-categories .category-card .category-card__image:hover img,
                  .block-categories .category-card .category-card__image:focus-within img {
                    transform: translateY(-4px) scale(1.03);
                    box-shadow: 0 8px 16px rgba(0,0,0,0.12);
                  }

                  /* Name: cleaner typography */
                  .block-categories .category-card .category-card__name {
                    font-size: 0.95rem;
                    line-height: 1.25;
                    margin-top: 4px;
                    max-width: 100%;
                  }
                  .block-categories .category-card .category-card__name a {
                    display: -webkit-box;
                    -webkit-line-clamp: 2;
                    -webkit-box-orient: vertical;
                    overflow: hidden;
                    text-overflow: ellipsis;
                  }

                  .block-categories .category-card .category-card__content {
                    display: flex;
                    flex-direction: column;
                    align-items: center;
                    gap: 2px;
                    margin-top: 6px;
                  }
                  .block-categories .category-card .category-card__all {
                    margin-top: 0;
                    font-size: 0.85rem;
                  }
                  .block-categories .category-card .category-card__products {
                    display: block;
                    font-size: 0.8rem;
                    color: #6c757d;
                  }

                  /* Tablet */
                  @media (max-width: 991px) {
                    .block-categories .category-card .category-card__body { padding: 10px 8px; }
                    .block-categories .category-card .category-card__name { font-size: 0.9rem; }
                  }

                  /* Mobile */
                  @media (max-width: 575px) {
                    .block-categories .category-card .category-card__body { padding: 8px 6px; }
                    .block-categories .category-card .category-card__image { padding: 4px; margin-bottom: 6px; }
                    .block-categories .category-card .category-card__name { font-size: 0.82rem; line-height: 1.2; margin-top: 2px; }
                    .block-categories .category-card .category-card__all { font-size: 0.78rem; }
                    .block-categories .category-card .category-card__products { font-size: 0.75rem; }
                  }
                </style>
                <div class="block-categories__list owl-carousel" id="categorias-carousel">
                  <% categorias.each do |categoria| %>
                    <div class="block-categories__item category-card category-card--layout--classic">
                      <div class="category-card__body">
                        <div class="category-card__image">
                          <a href="<%= home_categoria_path(categoria) %>">
                            <% if categoria.imagen.attached? %>
                              <%= image_tag categoria.imagen.variant(resize_to_limit: [400, 400]), alt: categoria.nombre, class: 'img-fluid' %>
                            <% else %>
                              <img src="/images/categories/default.jpg" alt="<%= categoria.nombre %>" class="img-fluid">
                            <% end %>
                          </a>
                        </div>
                        <div class="category-card__name">
                          <a href="<%= home_categoria_path(categoria) %>"> <%= categoria.nombre %> </a>
                        </div>
                        <div class="category-card__content">
                          <div class="category-card__all">
                            <a href="<%= home_categoria_path(categoria) %>">Ver todo</a>
                          </div>
                          <div class="category-card__products">
                            <%= categoria.productos.count %> Productos
                          </div>
                        </div>
                      </div>
                    </div>
                  <% end %>
                </div>
            <script>
              document.addEventListener('DOMContentLoaded', function() {
                if (window.$ && $.fn.owlCarousel) {
                  $('#categorias-carousel').owlCarousel({
                    items: 5,
                    loop: true,
                    margin: 10,
                    autoplay: true,
                    autoplayTimeout: 3500,
                    autoplayHoverPause: true,
                    responsive: {
                      0:    { items: 2, margin: 6 },
                      420:  { items: 3, margin: 8 },
                      576:  { items: 3, margin: 8 },
                      768:  { items: 4, margin: 10 },
                      992:  { items: 5, margin: 10 },
                      1200: { items: 5, margin: 12 }
                    }
                  });
                }
              });
            </script>
          </div>
        </div>
