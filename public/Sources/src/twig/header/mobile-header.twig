<!-- data-sticky-mode - one of [pullToShow, alwaysOnTop] -->
<div class="mobile-header mobile-header--sticky" data-sticky-mode="pullToShow">
    <div class="mobile-header__panel">
        <div class="container">
            <div class="mobile-header__body">
                <button class="mobile-header__menu-button">
                    <svg width="18px" height="14px">
                        <use xlink:href="images/sprite.svg#menu-18x14"></use>
                    </svg>
                </button>
                <a class="mobile-header__logo" href="index.html">
                    <!-- mobile-logo -->
                    <img class="mobile-header__img" src="/assets/slides/marca-007eaab71b848ee1763bee771f19d5b11ab4d309139e2b3f6eebeab611001cb6.jpg" alt="Fascy" style="height:80px;width:auto;">
                    <!-- mobile-logo / end -->
                </a>
                {# categories image removed #}

                {% include '/header/search.twig' with {
                    location: 'mobile-header',
                    classes: 'mobile-header__search'
                } only %}

                <div class="mobile-header__indicators">
                    <div class="indicator indicator--mobile-search indicator--mobile d-md-none">
                        <button class="indicator__button">
                            <span class="indicator__area">
                                <svg width="20px" height="20px"><use xlink:href="images/sprite.svg#search-20"></use></svg>
                            </span>
                        </button>
                    </div>

                    <div class="indicator indicator--mobile d-sm-flex d-none">
                        <a href="wishlist.html" class="indicator__button">
                            <span class="indicator__area">
                                <svg width="20px" height="20px"><use xlink:href="images/sprite.svg#heart-20"></use></svg>
                                <span class="indicator__value">0</span>
                            </span>
                        </a>
                    </div>

                    <div class="indicator indicator--mobile">
                        <a href="cart.html" class="indicator__button"{% if cart_style == 'offcanvas' %} data-open="offcanvas-cart"{% endif %}>
                            <span class="indicator__area">
                                <svg width="20px" height="20px"><use xlink:href="images/sprite.svg#cart-20"></use></svg>
                                <span class="indicator__value">3</span>
                            </span>
                        </a>
                    </div>
                </div>
            </div>
                                                    </div>
                                                    <script>
                                                    document.addEventListener('DOMContentLoaded', function(){
                                                        function clickWhenVisible(selector, attempts){
                                                            attempts = attempts || 8;
                                                            var el = document.querySelector(selector);
                                                            if(el && window.getComputedStyle(el).display !== 'none'){
                                                                el.click();
                                                                return true;
                                                            }
                                                            if(attempts <= 0) return false;
                                                            setTimeout(function(){ clickWhenVisible(selector, attempts-1); }, 150);
                                                            return false;
                                                        }

                                                        function openCategories(e){
                                                            if(e && e.preventDefault) e.preventDefault();
                                                            var deptBtn = document.querySelector('.departments__button');
                                                            if(deptBtn && window.getComputedStyle(deptBtn).display !== 'none'){
                                                                deptBtn.click();
                                                                return;
                                                            }
                                                            var menuBtn = document.querySelector('.mobile-header__menu-button');
                                                            if(menuBtn){
                                                                menuBtn.click();
                                                                setTimeout(function(){ clickWhenVisible('.departments__button'); }, 200);
                                                            }
                                                        }
                                                        var anchor = document.querySelector('.mobile-header__logo');
                                                        if(anchor){ anchor.style.cursor = 'pointer'; anchor.addEventListener('click', openCategories); }
                                                        // categories button removed
                                                    });
                                                    </script>
    </div>
</div>
